# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres_password
DB_DATABASE=municipality_db

# Service Ports
USER_SERVICE_PORT=3001
COMPLAINT_SERVICE_PORT=3002
FILE_UPLOAD_SERVICE_PORT=3003
AI_SERVICE_PORT=8000
FRONTEND_PORT=4200

# File Upload Configuration
# Supported: local, s3, cloudinary
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=./uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# AI & LLM Configuration
# Supported: ollama, gemini, openai, mock
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
GEMINI_API_KEY=
OPENAI_API_KEY=

# Service Endpoints (For cross-service communication)
USER_SERVICE_URL=http://localhost:3001
COMPLAINT_SERVICE_URL=http://localhost:3002
FILE_UPLOAD_SERVICE_URL=http://localhost:3003
AI_SERVICE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:4200
